# Docker Compose Environment Variables
# Copy this file to .env and fill in your values

# Build environment for frontend (dev or prod)
# Used by compose-dev.yaml when building from source
BUILD_ENV=dev

# Image names (used by compose.yaml for production)
# Leave as default to use ghcr.io registry images
# Or override to use local images built with compose-dev.yaml
BACKEND_API_IMAGE=ghcr.io/lemra-org/essentiel-backend-api:latest
FRONTEND_IMAGE=ghcr.io/lemra-org/essentiel-frontend:latest

# Google Sheets configuration (required for backend)
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"your-project"}
GOOGLE_SPREADSHEET_ID=your-spreadsheet-id-here

# CORS configuration
# Local dev: http://localhost:3000
# Production: https://your-domain.com
ALLOWED_ORIGIN=http://localhost:3000

# Cache configuration
CACHE_TTL_MINUTES=5

# Redis configuration
REDIS_ADDR=redis:6379

# Backend URL for nginx proxy in frontend container
# Docker compose uses internal service name
# Render will use internal service URL
BACKEND_URL=http://backend-api:8080
